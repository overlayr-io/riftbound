# Firebase Web SDK config (get it from Firebase Console → Project Settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=ritbound-tcg.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://rifbound-tcg-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=rifbound-tcg
VITE_FIREBASE_STORAGE_BUCKET=rifbound-tcg.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to connect to local Firebase Emulator Suite
VITE_USE_EMULATOR=true

# Backend API base URL
VITE_API_URL=http://localhost:3000
