PORT=3000
NODE_ENV=development

# Firebase
FIREBASE_PROJECT_ID=rifbound-tcg

# Production only: base64-encoded service account JSON
# Generate: base64 -i serviceAccount.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Set to "true" to connect to local Firebase Emulator Suite
USE_EMULATOR=true

# CORS: allowed client origin (comma-separated for multiple)
CLIENT_URL=http://localhost:5173
